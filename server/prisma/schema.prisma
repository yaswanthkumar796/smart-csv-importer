datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  password  String
  createdAt DateTime @default(now())
  groups    Group[]  @relation("AccountGroups")
}

model Group {
  id        Int       @id @default(autoincrement())
  name      String
  ownerId   Int
  createdAt DateTime  @default(now())
  owner     Account   @relation("AccountGroups", fields: [ownerId], references: [id])
  users     User[]    @relation("GroupUsers")
  expenses  Expense[]
}

model User {
  id           Int            @id @default(autoincrement())
  name         String
  groupId      Int
  createdAt    DateTime       @default(now())
  group        Group          @relation("GroupUsers", fields: [groupId], references: [id])
  expensesPaid Expense[]      @relation("PaidBy")
  splits       ExpenseSplit[]

  @@unique([name, groupId])
}

model Expense {
  id          Int            @id @default(autoincrement())
  groupId     Int
  description String
  date        DateTime
  amount      Float
  currency    String         @default("INR")
  paidById    Int
  splitType   String
  notes       String?
  createdAt   DateTime       @default(now())
  group       Group          @relation(fields: [groupId], references: [id])
  paidBy      User           @relation("PaidBy", fields: [paidById], references: [id])
  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id         Int     @id @default(autoincrement())
  expenseId  Int
  userId     Int
  amountOwed Float
  expense    Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id])
}
